<?xml version="1.0" encoding="utf-8"?>
<com.simplemobiletools.musicplayer.fragments.MultiQueueFragment xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/multi_queue_fragment_holder"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:id="@+id/multi_queue_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/medium_margin">

        <LinearLayout
            android:id="@+id/multi_queue_select_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="@dimen/activity_margin"
            android:paddingTop="@dimen/small_margin"
            android:paddingBottom="@dimen/small_margin"
            android:paddingEnd="@dimen/activity_margin">

            <com.simplemobiletools.commons.views.MyTextView
                android:id="@+id/current_queue_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:textSize="@dimen/bigger_text_size"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/current_queue_arrow"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="@dimen/small_margin"
                android:rotation="90"
                android:src="@drawable/ic_chevron_right_vector" />
        </LinearLayout>

        <ImageView
            android:id="@+id/multi_queue_play"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="@dimen/small_margin"
            android:src="@drawable/ic_play_vector" />
    </RelativeLayout>

    <com.simplemobiletools.commons.views.MyTextView
        android:id="@+id/multi_queue_placeholder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/multi_queue_header"
        android:layout_centerHorizontal="true"
        android:alpha="0.8"
        android:gravity="center"
        android:paddingStart="@dimen/activity_margin"
        android:paddingTop="@dimen/activity_margin"
        android:paddingEnd="@dimen/activity_margin"
        android:text="@string/no_items_found"
        android:textSize="@dimen/bigger_text_size"
        android:textStyle="italic" />

    <com.qtalk.recyclerviewfastscroller.RecyclerViewFastScroller
        android:id="@+id/multi_queue_fastscroller"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/multi_queue_header">

        <com.simplemobiletools.commons.views.MyRecyclerView
            android:id="@+id/multi_queue_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            app:layoutManager="com.simplemobiletools.commons.views.MyLinearLayoutManager" />

    </com.qtalk.recyclerviewfastscroller.RecyclerViewFastScroller>
</com.simplemobiletools.musicplayer.fragments.MultiQueueFragment>
